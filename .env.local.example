# Email configuration (for quote notifications)
# Uncomment and fill in to enable email sending
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your@email.com
# SMTP_PASS=your-app-password
# CONTACT_EMAIL=info@surreyflyscreens.co.uk

# Rate limiting (optional — defaults work fine)
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=900000
